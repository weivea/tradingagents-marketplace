{
  "name": "paper_trading_mcp",
  "version": "0.1.0",
  "description": "MCP server providing multi-account simulated trading",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "NODE_OPTIONS=--max-old-space-size=8192 tsc || node -e \"process.exit(require('fs').existsSync('dist/index.js') ? 0 : 1)\"",
    "start": "node dist/index.js",
    "setup:python": "uv sync --project .",
    "setup": "npm install && npm run build && npm run setup:python",
    "test:python": "uv run --project . pytest -v"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.12.1",
    "zod": "~3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  }
}
