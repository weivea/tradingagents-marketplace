# Futu OpenAPI 插件配置示例
# 复制本文件为 .env 后按需修改：
#   cp plugins/futu/.env.example plugins/futu/.env
#
# 加载规则：
#   1. 进程已存在的环境变量优先级最高（不会被 .env 覆盖）
#   2. 未设置的项才会从此文件填充
#   3. 路径支持 ~ 展开；相对路径以 plugins/futu/ 为基准

# ========== OpenD 连接 ==========
FUTU_OPEND_HOST=192.168.31.121
FUTU_OPEND_PORT=11111

# ========== RSA 加密（可选） ==========
# OpenD 与客户端共用同一份 PEM 私钥（1024 位 PKCS#1）
# 留空则禁用 InitConnect 加密
FUTU_RSA_KEY_FILE=~/.ssh/futu_id_rsa

# ========== 交易默认值（可选） ==========
# FUTU_TRD_ENV=SIMULATE
# FUTU_DEFAULT_MARKET=US
# FUTU_SECURITY_FIRM=FUTUSECURITIES
# FUTU_ACC_ID=
